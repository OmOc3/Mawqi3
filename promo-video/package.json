{
  "name": "ecopest-promo-video",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "audio": "node scripts/generate-audio.mjs",
    "render": "remotion render src/index.ts EcoPestPromo out/ecopest-promo.mp4 --codec=h264 --pixel-format=yuv420p",
    "still": "remotion still src/index.ts EcoPestPromo out/still.png --frame=180 --scale=0.35",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.392",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "remotion": "^4.0.392"
  },
  "devDependencies": {
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.3"
  }
}
