rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Client reads are only allowed after Firebase Auth is present.
    function signedIn() {
      return request.auth != null;
    }

    // User activity is checked from the canonical users/{uid} profile document.
    function activeUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // A signed-in user must also have an active app profile.
    function isActiveUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && activeUserDoc().data.isActive == true;
    }

    match /users/{uid} {
      // Users may read only their own active profile for future client auth state reads.
      allow read: if isActiveUser() && request.auth.uid == uid;

      // User management is server-only through Admin SDK Server Actions.
      allow create, update, delete: if false;
    }

    match /stations/{stationId} {
      // Stations are read and written by trusted server code only.
      allow read, write: if false;
    }

    match /reports/{reportId} {
      // Report submission, review, and export all go through Admin SDK.
      allow read, write: if false;
    }

    match /authRateLimits/{rateLimitId} {
      // Login throttling is managed by server auth endpoints only.
      allow read, write: if false;
    }

    match /{document=**} {
      // Default-deny keeps every new collection locked until reviewed.
      allow read, write: if false;
    }
  }
}
